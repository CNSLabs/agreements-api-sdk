{
  "name": "@cns-labs/agreements-api-client",
  "version": "0.0.2",
  "description": "TypeScript client for the Agreements API with built-in permit-signing helpers",
  "author": "Agreements API Maintainers",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CNSLabs/agreements-api-sdk.git",
    "directory": "packages/agreements-api-client"
  },
  "homepage": "https://github.com/CNSLabs/agreements-api-sdk/tree/main/packages/agreements-api-client#readme",
  "bugs": {
    "url": "https://github.com/CNSLabs/agreements-api-sdk/issues"
  },
  "keywords": [
    "agreements-protocol",
    "api",
    "client",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "pnpm run build",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@cns-labs/agreements-protocol-evm": "^0.0.2",
    "viem": "^2.43.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "typescript": "~5.6.2"
  },
  "engines": {
    "node": ">=18"
  }
}
