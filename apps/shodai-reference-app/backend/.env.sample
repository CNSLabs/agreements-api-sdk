AGREEMENTS_BACKEND_PORT=4199
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=standalone_agreements
FRONTEND_BASE_URL=http://localhost:5184/agreements/

# Dynamic
DYNAMIC_ENVIRONMENT_ID=
DYNAMIC_API_TOKEN=

# Optional RPC provider setting when VITE_AGREEMENTS_RPC_URL is not set.
INFURA_PROJECT_ID=

# Real Shodai external API. For local CNS stack testing, set
# EXTERNAL_API_BASE_URL to your local external-api URL and opt in with
# ALLOW_LOCAL_EXTERNAL_API=true. The opt-in is rejected under NODE_ENV=production.
EXTERNAL_API_BASE_URL=https://test-api.shodai.network
ALLOW_LOCAL_EXTERNAL_API=false
# Optional: explicitly pin public API environment if using a non-standard gateway URL.
# AGREEMENTS_API_ENVIRONMENT=testnet
# Optional: select the default chain from the SDK deployment registry for this API environment.
# DEFAULT_AGREEMENTS_CHAIN_ID=59141
# Required: generate a testnet key at https://developers.shodai.network/portal.
EXTERNAL_API_KEY=

# Signed webhook deliveries from Shodai. Store the secret returned when you
# create the webhook subscription.
SHODAI_WEBHOOK_SECRET=
# Optional: defaults to 300 seconds.
# SHODAI_WEBHOOK_TOLERANCE_SECONDS=300
# Optional webhook processor tuning. Defaults are production-shaped for a
# single reference backend process.
# SHODAI_WEBHOOK_PROCESSOR_INTERVAL_MS=1000
# SHODAI_WEBHOOK_PROCESSOR_MAX_ATTEMPTS=5
# SHODAI_WEBHOOK_PROCESSOR_RETRY_BASE_MS=1000
# SHODAI_WEBHOOK_PROCESSOR_RETRY_MAX_MS=900000
# SHODAI_WEBHOOK_PROCESSOR_LEASE_SECONDS=120

# Service/admin authorization
SERVICE_AUTH_TOKEN=

# Optional template catalog override; defaults to ../data/agreement-templates.
# AGREEMENT_TEMPLATES_DIR=
